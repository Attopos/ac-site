---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const featured = posts.find((post) => post.data.featured) ?? posts[0];
const archive = posts.filter((post) => post.id !== featured.id);
---

<BaseLayout title="Writing — Aaron Cao" currentPath="/writing">
  <section class="archive-hero" data-reveal>
    <p class="eyebrow">Writing / 03 entries</p>
    <h1>Ideas worth<br /><span>returning to.</span></h1>
    <p class="hero-text">Essays and field notes on systems, useful work, technology, and building a more deliberate life.</p>
  </section>

  <section class="writing-feature" data-reveal>
    <p class="section-kicker">Featured essay</p>
    <a class="featured-essay" href={`/writing/${featured.id}/`}>
      <div class="featured-art" aria-hidden="true">
        <div class="art-grid"></div><span class="art-orb"></span><span class="art-line"></span>
        <span class="art-label">AC — {featured.data.category}</span>
      </div>
      <div class="featured-copy">
        <div>
          <span class="category-pill">{featured.data.category}</span>
          <h3>{featured.data.title}</h3>
          <p>{featured.data.description}</p>
        </div>
        <div class="featured-meta">
          <span>{featured.data.publishedAt.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}</span>
          <span>{featured.data.readTime}</span><i>↗</i>
        </div>
      </div>
    </a>
  </section>

  <section class="section-block archive-section" data-reveal>
    <div class="archive-toolbar">
      <div>
        <p class="section-kicker">Archive</p>
        <h2>All writing</h2>
      </div>
      <span>{posts.length.toString().padStart(2, "0")} entries</span>
    </div>
    <div class="archive-list">
      {archive.map((post) => (
        <PostCard
          href={`/writing/${post.id}/`}
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          publishedAt={post.data.publishedAt}
          readTime={post.data.readTime}
        />
      ))}
    </div>
  </section>
</BaseLayout>
