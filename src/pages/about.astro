---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About — Aaron Cao" currentPath="/about">
  <section class="archive-hero about-hero" data-reveal>
    <p class="eyebrow">About / Now</p>
    <h1>Builder, writer,<br /><span>systems thinker.</span></h1>
    <p class="hero-text">I’m interested in how clear thinking, useful technology, and well-designed systems can create more freedom over time.</p>
  </section>

  <section class="about-grid" data-reveal>
    <article class="about-main">
      <p class="section-kicker">The short version</p>
      <h2>I use writing to make ideas legible—and building to make them real.</h2>
      <p>This site is a public workbench: a place to publish essays, document experiments, and trace the ideas that keep resurfacing.</p>
      <p>I care about durable skills, calm ambition, and structures that create room to think. The goal is not constant output. It is better direction.</p>
    </article>
    <aside class="now-panel">
      <div class="now-heading"><span class="status-dot"></span><p>Now</p><small>Updated 2026</small></div>
      <div class="now-item"><span>01</span><div><strong>Writing</strong><p>Systems, leverage, and intentional work.</p></div></div>
      <div class="now-item"><span>02</span><div><strong>Building</strong><p>A personal home for ideas and experiments.</p></div></div>
      <div class="now-item"><span>03</span><div><strong>Learning</strong><p>How technology expands individual agency.</p></div></div>
    </aside>
  </section>

  <section class="values-section" data-reveal>
    <div class="section-intro compact">
      <p class="section-kicker">Coordinates</p>
      <h2>What guides the work.</h2>
    </div>
    <div class="values-grid">
      <article><span>01</span><h3>Clarity</h3><p>Make the important thing easier to see.</p></article>
      <article><span>02</span><h3>Agency</h3><p>Build the capacity to choose and act.</p></article>
      <article><span>03</span><h3>Compounding</h3><p>Prefer work that becomes more useful over time.</p></article>
      <article><span>04</span><h3>Margin</h3><p>Leave space for judgment, surprise, and revision.</p></article>
    </div>
  </section>
</BaseLayout>
