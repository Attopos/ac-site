---
interface Props {
  href: string;
  title: string;
  description: string;
  category: string;
  publishedAt: Date;
  readTime: string;
}

const { href, title, description, category, publishedAt, readTime } = Astro.props;

const formattedDate = publishedAt.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric"
});
---

<article class="post-card">
  <a class="post-card-link" href={href}>
    <div class="post-card-top">
      <span class="category-pill">{category}</span>
      <span class="post-arrow" aria-hidden="true">↗</span>
    </div>
    <div class="post-card-copy">
      <h3>{title}</h3>
      <p>{description}</p>
    </div>
    <p class="post-meta">{formattedDate}<span></span>{readTime}</p>
  </a>
</article>
